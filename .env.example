# Travis MVP Environment Variables
# Copy this file to .env.local and fill in your API keys

# Supabase Configuration (Required)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# API Keys for Supabase Edge Functions
# These should be set in your Supabase Edge Functions environment

# Weather API (Required)
OPENWEATHER_API_KEY=your_openweather_api_key

# Maps & Places (Required)
MAPBOX_API_KEY=your_mapbox_api_key

# Currency Exchange (Required)
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key

# Time & Holidays (Required)
TIMEANDDATE_API_KEY=your_timeanddate_api_key

# Photos (Optional - has fallbacks)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Note: Uber API is not currently implemented as per SOW requirements
# UBER_CLIENT_ID=your_uber_client_id
# UBER_CLIENT_SECRET=your_uber_client_secret